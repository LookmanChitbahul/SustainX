# ─────────────────────────────────────────────────────────────
# SustainX Backend — Environment Variables Template
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# PostgreSQL (recommended)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/sustainx

# SQLite (local dev, no setup needed)
# DATABASE_URL=sqlite:///./sustainx.db

APP_ENV=development
SECRET_KEY=change-me-before-deploying
ALLOWED_ORIGINS=*
